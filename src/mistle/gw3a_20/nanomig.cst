IO_PORT "ext[4]" PULL_MODE=NONE IO_TYPE=LVCMOS33; 
IO_LOC "ext[5]" 96;
IO_PORT "ext[5]" PULL_MODE=NONE IO_TYPE=LVCMOS33; 

