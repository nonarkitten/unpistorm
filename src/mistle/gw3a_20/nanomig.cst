IO_PORT "ext[1]" PULL_MODE=NONE IO_TYPE=LVCMOS33; 
IO_LOC "ext[2]" 126;
IO_PORT "ext[2]" PULL_MODE=NONE IO_TYPE=LVCMOS33; 
